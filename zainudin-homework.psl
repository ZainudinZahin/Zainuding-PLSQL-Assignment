-- =========================================
-- 1. Rectangle Area Program
-- File: rectangle_area.sql
-- =========================================

DECLARE
    length NUMBER := 10;
    width  NUMBER := 5;
    area   NUMBER;
BEGIN
    area := length * width;

    DBMS_OUTPUT.PUT_LINE('Length: ' || length);
    DBMS_OUTPUT.PUT_LINE('Width: ' || width);
    DBMS_OUTPUT.PUT_LINE('Rectangle Area: ' || area);
END;
/